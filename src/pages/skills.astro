---
import Layout from "../layouts/Layout.astro";
import { profile } from "../data/profile";
---

<Layout title={`Skills | ${profile.name}`} description={`${profile.roleLine} — skills, tools, and strengths.`}>
  <h1 class="text-3xl font-semibold tracking-tight">Skills</h1>
  <p class="mt-2 text-slate-300 max-w-2xl">
    A focused, recruiter-friendly view of my analytics toolkit and strengths.
  </p>

  <div class="mt-8 grid gap-4 lg:grid-cols-3">
    <section class="rounded-xl border border-white/10 bg-white/5 p-6">
      <h2 class="text-lg font-semibold">Analytics & BI</h2>
      <ul class="mt-3 space-y-2 text-slate-300">
        <li class="list-disc ml-5">Power BI dashboards & KPI storytelling</li>
        <li class="list-disc ml-5">DAX measures, drill-down, segmentation</li>
        <li class="list-disc ml-5">Business reporting & decision support</li>
      </ul>
    </section>

    <section class="rounded-xl border border-white/10 bg-white/5 p-6">
      <h2 class="text-lg font-semibold">Data Analysis</h2>
      <ul class="mt-3 space-y-2 text-slate-300">
        <li class="list-disc ml-5">EDA, trends, outliers, hypothesis support</li>
        <li class="list-disc ml-5">Time series analysis & forecasting basics</li>
        <li class="list-disc ml-5">Data cleaning & transformation</li>
      </ul>
    </section>

    <section class="rounded-xl border border-white/10 bg-white/5 p-6">
      <h2 class="text-lg font-semibold">Applied ML</h2>
      <ul class="mt-3 space-y-2 text-slate-300">
        <li class="list-disc ml-5">Model evaluation & trade-offs</li>
        <li class="list-disc ml-5">Explainability (e.g., SHAP concepts)</li>
        <li class="list-disc ml-5">Threshold-based decision tuning</li>
      </ul>
    </section>
  </div>

  <section class="mt-10 rounded-xl border border-white/10 bg-white/5 p-6">
    <h2 class="text-lg font-semibold">Core tools</h2>
    <div class="mt-4 flex flex-wrap gap-2">
      {profile.coreTools.map((t) => (
        <span class="text-xs rounded-full border border-white/10 bg-white/5 px-3 py-1 text-slate-300">{t}</span>
      ))}
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-lg font-semibold">Want to see proof?</h2>
    <p class="mt-2 text-slate-300">
      Explore the <a class="text-sky-400 hover:underline" href="/projects">case studies</a> for dashboards, analysis, and deployed workflows.
    </p>
  </section>
</Layout>
