---
import Layout from "../layouts/Layout.astro";
import { projects } from "../data/projects";
import { profile } from "../data/profile";

const featured = projects.filter((p) => p.featured);
---

<Layout
  title={`${profile.name} | Data Analyst`}
  description={profile.tagline}
>
  <section class="py-6">
    <p class="text-sm text-sky-400 font-medium">{profile.roleLine}</p>
    <h1 class="mt-2 text-4xl sm:text-5xl font-semibold tracking-tight">
      BI & Predictive Insights for Real-World Decisions.
    </h1>

    <p class="mt-4 text-slate-300 max-w-2xl leading-relaxed">
      {profile.tagline}
    </p>


    <div class="mt-6 flex gap-3">
      <a class="rounded-lg bg-sky-400 text-slate-950 px-4 py-2 text-sm font-semibold hover:opacity-90" href="/projects">
        View Projects
      </a>
      <a class="rounded-lg border border-white/10 px-4 py-2 text-sm text-slate-100 hover:bg-white/5" href="/resume">
        Resume (PDF)
      </a>
      <a class="rounded-lg border border-white/10 px-4 py-2 text-sm text-slate-100 hover:bg-white/5" href="/contact">
        Contact
      </a>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-semibold">Experience</h2>
    <p class="mt-2 text-slate-300 max-w-2xl">
      A quick overview of applied analytics, BI work, and leadership experience that supports my Data Analyst profile.
    </p>

    <div class="mt-4 grid gap-4 lg:grid-cols-3">
      <div class="rounded-xl border border-white/10 bg-white/5 p-6">
        <div class="text-sm text-slate-400">Applied Analytics Projects</div>
        <h3 class="mt-2 font-semibold">End-to-end analysis & decision support</h3>
        <ul class="mt-3 space-y-2 text-slate-300">
          <li class="list-disc ml-5">Predictive maintenance and risk monitoring workflows</li>
          <li class="list-disc ml-5">Fraud detection evaluation and threshold trade-off analysis</li>
          <li class="list-disc ml-5">Exploratory analysis across large transaction and sales datasets</li>
        </ul>
      </div>

      <div class="rounded-xl border border-white/10 bg-white/5 p-6">
        <div class="text-sm text-slate-400">Business Intelligence & Reporting</div>
        <h3 class="mt-2 font-semibold">Dashboarding and KPI storytelling</h3>
        <ul class="mt-3 space-y-2 text-slate-300">
          <li class="list-disc ml-5">Power BI dashboards for sales trends and performance insights</li>
          <li class="list-disc ml-5">MySQL + DAX-based reporting workflows</li>
          <li class="list-disc ml-5">Executive-friendly views for monitoring and decision support</li>
        </ul>
      </div>

      <div class="rounded-xl border border-white/10 bg-white/5 p-6">
        <div class="text-sm text-slate-400">Leadership & Operations</div>
        <h3 class="mt-2 font-semibold">Team coordination and event execution</h3>
        <ul class="mt-3 space-y-2 text-slate-300">
          <li class="list-disc ml-5">Vice President — APU Bangladesh Society</li>
          <li class="list-disc ml-5">Sports Secretary — Bangladesh Student Organisation of Malaysia</li>
          <li class="list-disc ml-5">Led multi-team events (100–1000 attendees / participants)</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="mt-12">
    <div class="flex items-end justify-between gap-4">
      <h2 class="text-xl font-semibold">Areas of Interest</h2>
      <a class="text-sm text-sky-400 hover:underline" href="/skills">View full skills →</a>
    </div>

    <p class="mt-2 text-slate-300 max-w-2xl">
      The kinds of work I can contribute to in a Data Analyst role (and the services I can provide for project-based collaboration).
    </p>

    <div class="mt-4 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      <div class="rounded-xl border border-white/10 bg-white/5 p-6">
        <h3 class="font-semibold">BI Dashboard Development</h3>
        <p class="mt-2 text-sm text-slate-300">
          Build interactive Power BI dashboards with KPIs, drill-down analysis, and business storytelling for decision-makers.
        </p>
      </div>

      <div class="rounded-xl border border-white/10 bg-white/5 p-6">
        <h3 class="font-semibold">Data Cleaning & Analysis</h3>
        <p class="mt-2 text-sm text-slate-300">
          Perform EDA, trend analysis, segmentation, and insight generation using Python/R for reporting and planning.
        </p>
      </div>

      <div class="rounded-xl border border-white/10 bg-white/5 p-6">
        <h3 class="font-semibold">Predictive Analytics Prototyping</h3>
        <p class="mt-2 text-sm text-slate-300">
          Develop model prototypes, evaluate trade-offs, and present interpretable outputs for operational decision support.
        </p>
      </div>

      <div class="rounded-xl border border-white/10 bg-white/5 p-6">
        <h3 class="font-semibold">KPI Reporting & Monitoring</h3>
        <p class="mt-2 text-sm text-slate-300">
          Define and track core business metrics with consistent reporting structures for ongoing performance review.
        </p>
      </div>

      <div class="rounded-xl border border-white/10 bg-white/5 p-6">
        <h3 class="font-semibold">Data-to-Decision Workflows</h3>
        <p class="mt-2 text-sm text-slate-300">
          Translate business problems into data workflows that produce clear, actionable outputs for stakeholders.
        </p>
      </div>

      <div class="rounded-xl border border-white/10 bg-white/5 p-6">
        <h3 class="font-semibold">Lightweight Analytics Apps</h3>
        <p class="mt-2 text-sm text-slate-300">
          Build simple analytics interfaces using FastAPI + Streamlit for demos, internal tools, and decision support.
        </p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <div class="flex items-end justify-between gap-4">
      <h2 class="text-xl font-semibold">Featured Projects</h2>
      <a class="text-sm text-sky-400 hover:underline" href="/projects">All projects →</a>
    </div>

    <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {featured.map((p) => (
        <a
          class="group rounded-xl border border-white/10 bg-white/5 overflow-hidden hover:bg-white/10 transition"
          href={`/projects/${p.slug}`}
          target="_blank"
        >
          <div class="aspect-[16/9] bg-black/30 overflow-hidden">
            <img
              src={p.coverImage}
              alt={`${p.title} cover`}
              class="h-full w-full object-cover opacity-90 group-hover:opacity-100 transition"
              loading="lazy"
              onerror="this.onerror=null;this.src='/images/placeholder.svg';"
            />
          </div>
          <div class="p-5">
            <div class="text-xs text-slate-400">{p.category} • {p.dataset}</div>
            <div class="mt-1 font-semibold">{p.title}</div>
            <div class="mt-2 text-sm text-slate-300">{p.oneLiner}</div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="mt-12">
    <h2 class="text-xl font-semibold">Highlights</h2>

    <div class="mt-4 grid gap-4 lg:grid-cols-3">
      <div class="rounded-xl border border-white/10 bg-white/5 p-6">
        <div class="text-sm text-slate-400">Focus</div>
        <ul class="mt-3 space-y-2 text-slate-300">
          <li class="list-disc ml-5">BI dashboards & KPI storytelling</li>
          <li class="list-disc ml-5">EDA, trend analysis, reporting</li>
          <li class="list-disc ml-5">Decision-support workflows (API + UI)</li>
        </ul>
      </div>

      <div class="rounded-xl border border-white/10 bg-white/5 p-6">
        <div class="text-sm text-slate-400">Core tools</div>
        <div class="mt-3 flex flex-wrap gap-2">
          {profile.coreTools.map((t) => (
            <span class="text-xs rounded-full border border-white/10 bg-white/5 px-3 py-1 text-slate-300">{t}</span>
          ))}

        </div>
      </div>

      <div class="rounded-xl border border-white/10 bg-white/5 p-6">
        <div class="text-sm text-slate-400">Quick stats</div>
        <div class="mt-4 grid grid-cols-3 gap-3">
          {profile.stats.map((s) => (
            <div class="rounded-lg border border-white/10 bg-black/20 p-3 text-center">
              <div class="text-lg font-semibold">{s.value}</div>
              <div class="text-xs text-slate-400">{s.label}</div>
            </div>
          ))}
        </div>


        <p class="mt-4 text-sm text-slate-300">
          Want the details? Explore the <a class="text-sky-400 hover:underline" href="/projects">case studies</a>.
        </p>
      </div>
    </div>
  </section>

</Layout>