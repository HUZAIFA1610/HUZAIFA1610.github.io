---
import Layout from "../layouts/Layout.astro";
import { projects } from "../data/projects";

const featured = projects.filter((p) => p.featured);
---

<Layout
  title="Mohammad Abu Huzaifa | Data Analyst"
  description="Data Analyst portfolio: dashboards, analytics, and decision support."
>
  <section class="py-6">
    <p class="text-sm text-sky-400 font-medium">Data Analyst</p>
    <h1 class="mt-2 text-4xl sm:text-5xl font-semibold tracking-tight">
      BI & Predictive Insights for Real-World Decisions.
    </h1>

    <p class="mt-4 text-slate-300 max-w-2xl leading-relaxed">
      I turn complex datasets into executive-ready dashboards, risk signals, and decision support—using Python, SQL, and Power BI.
    </p>

    <div class="mt-6 flex gap-3">
      <a class="rounded-lg bg-sky-400 text-slate-950 px-4 py-2 text-sm font-semibold hover:opacity-90" href="/projects">
        View Projects
      </a>
      <a class="rounded-lg border border-white/10 px-4 py-2 text-sm text-slate-100 hover:bg-white/5" href="/resume">
        Resume
      </a>
      <a class="rounded-lg border border-white/10 px-4 py-2 text-sm text-slate-100 hover:bg-white/5" href="/contact">
        Contact
      </a>
    </div>
  </section>

  <section class="mt-10">
    <div class="flex items-end justify-between gap-4">
      <h2 class="text-xl font-semibold">Featured Projects</h2>
      <a class="text-sm text-sky-400 hover:underline" href="/projects">All projects →</a>
    </div>

    <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {featured.map((p) => (
        <a
          class="group rounded-xl border border-white/10 bg-white/5 overflow-hidden hover:bg-white/10 transition"
          href={`/projects/${p.slug}`}
          target="_blank"
        >
          <div class="aspect-[16/9] bg-black/30 overflow-hidden">
            <img
              src={p.coverImage}
              alt={`${p.title} cover`}
              class="h-full w-full object-cover opacity-90 group-hover:opacity-100 transition"
              loading="lazy"
              onerror="this.onerror=null;this.src='/images/placeholder.svg';"
            />
          </div>
          <div class="p-5">
            <div class="text-xs text-slate-400">{p.category} • {p.dataset}</div>
            <div class="mt-1 font-semibold">{p.title}</div>
            <div class="mt-2 text-sm text-slate-300">{p.oneLiner}</div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="mt-12">
    <h2 class="text-xl font-semibold">Highlights</h2>

    <div class="mt-4 grid gap-4 lg:grid-cols-3">
      <div class="rounded-xl border border-white/10 bg-white/5 p-6">
        <div class="text-sm text-slate-400">Focus</div>
        <ul class="mt-3 space-y-2 text-slate-300">
          <li class="list-disc ml-5">BI dashboards & KPI storytelling</li>
          <li class="list-disc ml-5">EDA, trend analysis, reporting</li>
          <li class="list-disc ml-5">Decision-support workflows (API + UI)</li>
        </ul>
      </div>

      <div class="rounded-xl border border-white/10 bg-white/5 p-6">
        <div class="text-sm text-slate-400">Core tools</div>
        <div class="mt-3 flex flex-wrap gap-2">
          {["Python", "Power BI", "MySQL", "R", "FastAPI", "Streamlit", "Excel"].map((t) => (
            <span class="text-xs rounded-full border border-white/10 bg-white/5 px-3 py-1 text-slate-300">{t}</span>
          ))}
        </div>
      </div>

      <div class="rounded-xl border border-white/10 bg-white/5 p-6">
        <div class="text-sm text-slate-400">Quick stats</div>
        <div class="mt-4 grid grid-cols-3 gap-3">
          <div class="rounded-lg border border-white/10 bg-black/20 p-3 text-center">
            <div class="text-lg font-semibold">10+</div>
            <div class="text-xs text-slate-400">Projects</div>
          </div>
          <div class="rounded-lg border border-white/10 bg-black/20 p-3 text-center">
            <div class="text-lg font-semibold">2.82M</div>
            <div class="text-xs text-slate-400">Largest dataset</div>
          </div>
          <div class="rounded-lg border border-white/10 bg-black/20 p-3 text-center">
            <div class="text-lg font-semibold">BI</div>
            <div class="text-xs text-slate-400">Dashboards</div>
          </div>
        </div>

        <p class="mt-4 text-sm text-slate-300">
          Want the details? Explore the <a class="text-sky-400 hover:underline" href="/projects">case studies</a>.
        </p>
      </div>
    </div>
  </section>

</Layout>