---
import Layout from "../layouts/Layout.astro";
import { profile } from "../data/profile";

const bookingLink = (profile.links.booking ?? "").trim();
const hasRealBookingLink =
  bookingLink.length > 0 &&
  !bookingLink.includes("your-username") &&
  !bookingLink.includes("example.com");
---

<Layout
  title={`Contact | ${profile.name}`}
  description={`Contact ${profile.name} — ${profile.roleLine}`}
>
  <h1 class="text-3xl font-semibold tracking-tight">Contact</h1>

  <div class="mt-3 flex flex-wrap gap-2">
    <span class="text-xs rounded-full border border-sky-400/30 bg-sky-400/10 px-3 py-1 text-sky-200">
      Open to Data Analyst roles
    </span>
    <span class="text-xs rounded-full border border-white/10 bg-white/5 px-3 py-1 text-slate-300">
      BI • Predictive Insights • Decision Support
    </span>
    <span class="text-xs rounded-full border border-white/10 bg-white/5 px-3 py-1 text-slate-300">
      {profile.location}
    </span>
  </div>

  <div class="mt-8 grid gap-6 lg:grid-cols-3">
    <section class="lg:col-span-2 rounded-xl border border-white/10 bg-white/5 p-6">
      <h2 class="text-lg font-semibold">Best way to reach me</h2>
      <p class="mt-2 text-slate-300 leading-relaxed">
        Email is the fastest. If you’re reaching out about a Data Analyst position, include the role title and a quick note about what you’d like me to focus on (BI dashboards, analysis, or predictive work).
      </p>

      <div class="mt-6 rounded-xl border border-white/10 bg-black/20 p-5">
        <div class="text-sm text-slate-400">Email</div>
        <div class="mt-1 flex flex-wrap items-center gap-3">
          <a class="text-sky-400 hover:underline" href={`mailto:${profile.email}`}>
            {profile.email}
          </a>
          <button
            id="copy-email"
            type="button"
            class="rounded-lg border border-white/10 px-3 py-1.5 text-xs text-slate-200 hover:bg-white/5"
          >
            Copy
          </button>
          <span id="copy-status" class="text-xs text-slate-400"></span>
        </div>
      </div>

      <div class="mt-6 grid gap-3 sm:grid-cols-2">
        <a class="rounded-xl border border-white/10 bg-white/5 p-5 hover:bg-white/10 transition"
           href={profile.links.linkedin} target="_blank" rel="noopener noreferrer">
          <div class="text-sm text-slate-400">LinkedIn</div>
          <div class="mt-1 font-semibold">View profile</div>
          <div class="mt-2 text-sm text-slate-300">Recruiter-friendly summary and links</div>
        </a>

        <a class="rounded-xl border border-white/10 bg-white/5 p-5 hover:bg-white/10 transition"
           href={profile.links.github} target="_blank" rel="noopener noreferrer">
          <div class="text-sm text-slate-400">GitHub</div>
          <div class="mt-1 font-semibold">View repositories</div>
          <div class="mt-2 text-sm text-slate-300">Code, notebooks, dashboards, and case studies</div>
        </a>
      </div>
    </section>

    <aside class="rounded-xl border border-white/10 bg-white/5 p-6 h-fit">
      <h2 class="text-lg font-semibold">Quick info</h2>
      <div class="mt-3 text-sm text-slate-300 space-y-2">
        <p><span class="text-slate-400">Name:</span> {profile.name}</p>
        <p><span class="text-slate-400">Role:</span> {profile.roleLine}</p>
        <p><span class="text-slate-400">Location:</span> {profile.location}</p>
      </div>

      <h2 class="mt-6 text-lg font-semibold">Resume</h2>
      <a class="mt-3 inline-flex w-full items-center justify-center rounded-lg bg-sky-400 px-4 py-2 text-sm font-semibold text-slate-950 hover:opacity-90"
         href="/resume" >
        View Resume
      </a>
      <a class="mt-3 inline-flex w-full items-center justify-center rounded-lg border border-white/10 px-4 py-2 text-sm text-slate-100 hover:bg-white/5"
         href="/resume.pdf" target="_blank" rel="noopener noreferrer">
        Download PDF
      </a>
      {hasRealBookingLink ? (
        <>
          <h2 class="mt-6 text-lg font-semibold">Book a meeting</h2>
          <p class="mt-2 text-sm text-slate-300">
            Prefer a quick discussion? Book a short call for portfolio review, collaboration, or analytics project discussion.
          </p>

          <a
            class="mt-3 inline-flex w-full items-center justify-center rounded-lg border border-white/10 px-4 py-2 text-sm text-slate-100 hover:bg-white/5"
            href={bookingLink}
            target="_blank"
            rel="noopener noreferrer"
          >
            Book a 30-min meeting
          </a>
        </>
      ) : null}
    </aside>
  </div>

  <script>
    const btn = document.getElementById("copy-email");
    const status = document.getElementById("copy-status");
    const email = "{profile.email}";

    if (btn) {
      btn.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(email);
          if (status) status.textContent = "Copied ✅";
          setTimeout(() => { if (status) status.textContent = ""; }, 1200);
        } catch (e) {
          if (status) status.textContent = "Copy failed — please copy manually";
        }
      });
    }
  </script>
</Layout>
