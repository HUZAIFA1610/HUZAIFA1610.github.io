---
import Layout from "../layouts/Layout.astro";
import { profile } from "../data/profile";
---

<Layout
  title={`About | ${profile.name}`}
  description={`About ${profile.name} — ${profile.roleLine}`}
>
  <h1 class="text-3xl font-semibold tracking-tight">About</h1>

  <div class="mt-6 grid gap-8 lg:grid-cols-3">
    <section class="lg:col-span-2">
      <h2 class="text-lg font-semibold">Profile</h2>
      <p class="mt-2 text-slate-300 leading-relaxed">
        I’m a Data Analyst focused on converting large, complex datasets into clear insights and decision support.
        My work spans BI dashboards, exploratory analysis, and deployable analytics workflows—bridging stakeholder needs
        with technical execution.
      </p>

      <h2 class="mt-6 text-lg font-semibold">What I deliver</h2>
      <ul class="mt-2 grid gap-2 text-slate-300 list-disc pl-5">
        <li><span class="font-medium text-slate-100">BI dashboards</span> with KPI storytelling (Power BI, DAX, MySQL)</li>
        <li><span class="font-medium text-slate-100">Data analysis</span> for trends, segmentation, and reporting (Python/R)</li>
        <li><span class="font-medium text-slate-100">Decision-support systems</span> (APIs + lightweight interfaces) for real operations</li>
      </ul>

      <h2 class="mt-6 text-lg font-semibold">Experience snapshot</h2>
      <div class="mt-3 grid gap-4 sm:grid-cols-2">
        <div class="rounded-xl border border-white/10 bg-white/5 p-5">
          <div class="text-sm text-slate-400">Analytics & BI</div>
          <ul class="mt-2 space-y-2 text-slate-300">
            <li class="list-disc ml-5">Power BI dashboards with KPI storytelling and drill-down</li>
            <li class="list-disc ml-5">SQL-backed reporting and data transformations</li>
            <li class="list-disc ml-5">Time-series trend analysis and performance insights</li>
          </ul>
        </div>

        <div class="rounded-xl border border-white/10 bg-white/5 p-5">
          <div class="text-sm text-slate-400">Applied ML / Decision Support</div>
          <ul class="mt-2 space-y-2 text-slate-300">
            <li class="list-disc ml-5">Predictive analytics workflows for risk monitoring</li>
            <li class="list-disc ml-5">Model evaluation trade-offs and threshold-based decisions</li>
            <li class="list-disc ml-5">Deployable analytics via API + lightweight UI</li>
          </ul>
        </div>
      </div>


      <h2 class="mt-6 text-lg font-semibold">Featured work</h2>
      <ul class="mt-2 grid gap-2 text-slate-300 list-disc pl-5">
        <li><a class="text-sky-400 hover:underline" href="/projects/water-quality">AI-Driven Water Quality Monitoring & Predictive Maintenance</a> — 2.82M records + explainable risk tiers</li>
        <li><a class="text-sky-400 hover:underline" href="/projects/fraud-detection">Deep Learning Fraud Detection</a> — threshold-driven decision support</li>
        <li><a class="text-sky-400 hover:underline" href="/projects/fusion-bikes-bi">Fusion Bikes BI</a> — 10M rows BI pipeline + dashboards</li>
      </ul>

      <h2 class="mt-6 text-lg font-semibold">Leadership & community</h2>
      <ul class="mt-2 grid gap-2 text-slate-300 list-disc pl-5">
        <li>Hosted a Bangladeshi Cultural Night in Malaysia (≈1000 attendees)</li>
        <li>Launched an Inter-University Futsal Tournament in Kuala Lumpur (16 teams)</li>
        <li>Organized an Iftar program (≈100 attendees)</li>
        <li>Vice President — APU Bangladesh Society</li>
        <li>Sports Secretary — Bangladesh Student Organisation of Malaysia</li>
      </ul>

      <div class="mt-8 flex gap-3">
        <a class="rounded-lg bg-sky-400 text-slate-950 px-4 py-2 text-sm font-semibold hover:opacity-90" href="/projects">
          View Projects
        </a>
        <a class="rounded-lg border border-white/10 px-4 py-2 text-sm text-slate-100 hover:bg-white/5" href="/resume">
          Resume
        </a>
        <a class="rounded-lg border border-white/10 px-4 py-2 text-sm text-slate-100 hover:bg-white/5" href="/contact">
          Contact
        </a>
      </div>
    </section>

    <aside class="rounded-xl border border-white/10 bg-white/5 p-5 h-fit">
      <h2 class="text-lg font-semibold">Quick facts</h2>
      <div class="mt-3 text-sm text-slate-300 space-y-2">
        <p><span class="text-slate-400">Role:</span> {profile.roleLine}</p>
        <p><span class="text-slate-400">Degree:</span> BSc Computer Science (Data Analytics)</p>
        <p><span class="text-slate-400">Location:</span> {profile.location}</p>
        <p>
          <span class="text-slate-400">Email:</span>{" "}
          <a class="text-sky-400 hover:underline" href={`mailto:${profile.email}`}>
            {profile.email}
          </a>
        </p>
      </div>


      <h2 class="mt-6 text-lg font-semibold">Core tools</h2>
      <div class="mt-3 flex flex-wrap gap-2">
        {profile.coreTools.map((t) => (
          <span class="text-xs rounded-full border border-white/10 bg-white/5 px-3 py-1 text-slate-300">{t}</span>
        ))}

      </div>
    </aside>
  </div>
</Layout>